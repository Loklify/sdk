{
  "name": "@loklify/vue",
  "version": "0.1.0",
  "description": "Loklify SDK — Vue plugin",
  "type": "module",
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch"
  },
  "peerDependencies": {
    "vue":      ">=3.3.0",
    "vue-i18n": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "vue-i18n": { "optional": true }
  },
  "dependencies": {
    "@loklify/core": "workspace:*"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "^5.4.0",
    "vue":        "^3.4.0",
    "vue-i18n":   "^9.13.0"
  }
}
