{
  "name": "@loklify/vue",
  "version": "0.1.5",
  "description": "Loklify SDK · Vue 3 plugin with vue-i18n integration. Load your translations from Loklify at runtime.",
  "keywords": [
    "loklify",
    "vue",
    "vue3",
    "vue-i18n",
    "i18n",
    "internationalization",
    "translations",
    "translation-management",
    "localization",
    "l10n"
  ],
  "homepage": "https://loklify.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loklify/sdk.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/loklify/sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "vue-i18n": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "vue-i18n": {
      "optional": true
    }
  },
  "dependencies": {
    "@loklify/core": "^0.1.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.13.0"
  }
}
